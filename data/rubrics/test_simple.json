{
  "name": "Simple Math Test",
  "description": "Quick rubric for testing the assessment system",
  "subject": "Mathematics",
  "level": "Primary 1",
  "criteria": [
    {
      "name": "Correctness",
      "description": "Is the answer correct?",
      "max_score": 10,
      "levels": {
        "0": "Completely wrong",
        "5": "Partially correct",
        "10": "Completely correct"
      }
    },
    {
      "name": "Explanation",
      "description": "Did the student explain their answer?",
      "max_score": 5,
      "levels": {
        "0": "No explanation",
        "3": "Brief explanation",
        "5": "Clear explanation"
      }
    }
  ]
}
